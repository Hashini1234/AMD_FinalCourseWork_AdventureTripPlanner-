# Copy this file to ".env" and fill in your own values.
# Expo automatically inlines any variable prefixed with EXPO_PUBLIC_ at build time.
# Never commit the real ".env" file — it is already excluded in .gitignore.

# ---- Backend ----
# This project uses the coursework's "mock server" option: authentication and
# CRUD data are simulated locally (AsyncStorage) in src/mock and src/services -
# no server URL or backend credentials are required to run the app.

# ---- OpenWeather REST API ----
# https://openweathermap.org/api -> free tier API key
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key
